NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://yoursite.example.com
NEXT_PUBLIC_RESUME_URL=https://resume.yoursite.example.com
NEXT_PUBLIC_BLOG_URL=https://blog.yoursite.example.com

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5
OPENAI_FAST_CHAT_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional only if you want PostgreSQL persistence. Leave empty to use file fallback.
DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/ai_site
OBSERVABILITY_STORE_FILENAME=observability-store.json
SOURCE_SYNC_STATE_FILENAME=source-sync-state.json
SOURCE_RECORDS_FILENAME=source-records.json

# Public-account aggregation works without a token, but a token avoids stricter rate limits.
GITHUB_TOKEN=
GITHUB_ACCOUNT_USERNAME=your-github-username

WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=1500
JOB_RUNS_STORE_FILENAME=job-runs.json
EVOLUTION_RUNS_STORE_FILENAME=evolution-runs.json
BLOG_SOURCE_DIR=../blog
GITHUB_SYNC_CRON=*/30 * * * *
BLOG_SYNC_CRON=0 */6 * * *
WEEKLY_DIGEST_CRON=0 9 * * 1

ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
